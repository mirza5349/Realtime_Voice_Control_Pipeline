APP_NAME=local-voice-ai-pipeline
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_API_V1_PREFIX=/api/v1
STT_PROVIDER=whisper_cpp
WHISPER_CPP_BINARY_PATH=
WHISPER_CPP_MODEL_PATH=
WHISPER_CPP_THREADS=4
WHISPER_CPP_LANGUAGE=
UPLOAD_MAX_BYTES=10485760
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
LLM_REQUEST_TIMEOUT_SECONDS=30
SESSION_HISTORY_LIMIT=10
TTS_PROVIDER=piper
PIPER_BINARY_PATH=
PIPER_MODEL_PATH=
AUDIO_STORAGE_DIR=.data/audio
AUDIO_PUBLIC_BASE_PATH=/api/v1/audio
AUDIO_FILE_TTL_SECONDS=3600
TRACE_HISTORY_LIMIT=100
METRICS_RETENTION_LIMIT=500
DEMO_RUNNER_TIMEOUT_SECONDS=60
DEMO_MODE=true
DEMO_AUTO_CLEANUP_AUDIO=true
DEMO_STARTUP_VALIDATE_PROVIDERS=true
DEMO_SAMPLES_DIR=.data/demo_assets
DEMO_SAMPLES_PUBLIC_PATH=/api/v1/demo/samples
DEMO_CLEANUP_INTERVAL_SECONDS=300
LIVE_AUDIO_ENABLED=true
LIVE_AUDIO_MAX_SECONDS_PER_UTTERANCE=10
LIVE_AUDIO_MIN_SECONDS_PER_UTTERANCE=0.5
LIVE_AUDIO_MAX_QUEUE_PER_SESSION=5
LIVE_AUDIO_AUTOPLAY_DEFAULT=true
LIVE_AUDIO_SILENCE_WINDOW_MS=1200
